// Schema do banco — app Despensa (Fase 0)
// Convenção: domínio em português; modelos do Auth.js em inglês (contrato da lib).
// Ver docs/spec-tecnica.md §3 (modelagem) e §7 (convenções de nomenclatura).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: a URL de conexão fica em prisma.config.ts (Migrate/CLI) e no
  // driver adapter do PrismaClient (runtime). Ambos leem env DATABASE_URL.
}

// ───────────────────────────────────────────────
// Autenticação — modelos impostos pelo Auth.js (inglês)
// ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts  Account[]
  sessions  Session[]
  moradores Morador[] // vínculos do usuário com Casas
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ───────────────────────────────────────────────
// Domínio — português
// ───────────────────────────────────────────────

model Casa {
  id       String   @id @default(cuid())
  nome     String
  criadaEm DateTime @default(now())

  moradores     Morador[]
  itens         Item[]
  compras       Compra[]
  despensaItens DespensaItem[]
  ajustes       AjusteDespensa[]
  listaItens    ListaItem[]
}

model Morador {
  id        String       @id @default(cuid())
  usuarioId String
  casaId    String
  papel     PapelMorador @default(MEMBRO)
  criadoEm  DateTime     @default(now())

  usuario            User      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  casa               Casa      @relation(fields: [casaId], references: [id], onDelete: Cascade)
  comprasRegistradas Compra[]

  @@unique([usuarioId, casaId]) // um usuário entra uma vez por Casa
  @@index([casaId])
}

model Item {
  id            String   @id @default(cuid())
  casaId        String
  nomeCanonico  String
  categoria     String?
  unidadePadrao String? // ex.: "un", "kg", "L"
  criadoEm      DateTime @default(now())

  casa         Casa             @relation(fields: [casaId], references: [id], onDelete: Cascade)
  apelidos     ApelidoItem[]
  compraItens  CompraItem[]
  despensaItem DespensaItem?
  ajustes      AjusteDespensa[]
  listaItens   ListaItem[]

  @@unique([casaId, nomeCanonico]) // Item canônico único por Casa
  @@index([casaId])
}

model ApelidoItem {
  id         String   @id @default(cuid())
  itemId     String
  textoBruto String // texto digitado/OCR que mapeia para o Item
  criadoEm   DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, textoBruto])
  @@index([itemId])
}

model Compra {
  id          String   @id @default(cuid())
  casaId      String
  data        DateTime
  valorTotal  Decimal? @db.Decimal(10, 2)
  criadaPorId String? // Morador que registrou (opcional; prepara F5)
  criadaEm    DateTime @default(now())

  casa      Casa         @relation(fields: [casaId], references: [id], onDelete: Cascade)
  criadaPor Morador?     @relation(fields: [criadaPorId], references: [id], onDelete: SetNull)
  itens     CompraItem[]

  @@index([casaId, data])
}

model CompraItem {
  id         String   @id @default(cuid())
  compraId   String
  itemId     String
  quantidade Decimal  @db.Decimal(10, 3)
  unidade    String?
  precoUnit  Decimal? @db.Decimal(10, 2)

  compra Compra @relation(fields: [compraId], references: [id], onDelete: Cascade)
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([compraId])
  @@index([itemId])
}

model DespensaItem {
  id             String    @id @default(cuid())
  casaId         String
  itemId         String    @unique // 1 estimativa por Item
  qtdEstimada    Decimal   @db.Decimal(10, 3)
  confianca      Float     @default(0) // pontuação interna 0–1; vira semáforo na UI
  ultimaCompraEm DateTime?
  atualizadoEm   DateTime  @updatedAt

  casa Casa @relation(fields: [casaId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([casaId])
}

model AjusteDespensa {
  id     String     @id @default(cuid())
  casaId String
  itemId String
  tipo   TipoAjuste
  valor  Decimal?   @db.Decimal(10, 3) // usado no "Ajuste preciso"
  em     DateTime   @default(now())

  casa Casa @relation(fields: [casaId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([casaId, itemId, em]) // histórico de proxies por Item
}

model ListaItem {
  id           String          @id @default(cuid())
  casaId       String
  itemId       String
  origem       OrigemItem
  motivo       MotivoSugestao?
  qtdSugerida  Decimal?        @db.Decimal(10, 3)
  status       StatusListaItem @default(ATIVO)
  criadoEm     DateTime        @default(now())
  atualizadoEm DateTime        @updatedAt

  casa Casa @relation(fields: [casaId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([casaId, status])
}

// ───────────────────────────────────────────────
// Enums
// ───────────────────────────────────────────────

enum PapelMorador {
  DONO
  MEMBRO
}

enum TipoAjuste {
  TEM
  POUCO
  ACABOU
  PRECISO
}

enum OrigemItem {
  SUGESTAO
  MANUAL
}

enum MotivoSugestao {
  PROVAVELMENTE_ACABANDO
  RECORRENTE
  MANUAL
}

enum StatusListaItem {
  ATIVO
  ACEITO
  DISPENSADO
  COMPRADO
}
