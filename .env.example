# Modelo de variáveis de ambiente. Copie para `.env.local` e ajuste os valores.
#   cp .env.example .env.local
#
# .env.local  -> desenvolvimento (banco Docker local); ignorado pelo Git.
# Produção    -> variáveis definidas no painel da Vercel (banco Neon).

# ── Banco de dados ────────────────────────────────────────────────
# Desenvolvimento (Docker Compose, ver docker-compose.yml):
DATABASE_URL="postgresql://despensa:despensa@localhost:5432/despensa?schema=public"

# Produção (Neon) — exemplo do formato; use a connection string do painel Neon.
# Prefira a URL "pooled" (host com -pooler) para o runtime serverless da Vercel.
# DATABASE_URL="postgresql://USUARIO:SENHA@ep-xxxx-pooler.REGIAO.aws.neon.tech/despensa?sslmode=require"

# ── Autenticação (Auth.js / NextAuth v5) ──────────────────────────
# Segredo de assinatura de sessão — gere com: npx auth secret
AUTH_SECRET=""

# Google OAuth — credenciais do Google Cloud Console (OAuth 2.0 Client ID).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
